<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- 通知监听权限（自动记账核心） -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- 无障碍权限（屏幕识别退款） -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions" />


    <application
        android:name=".LedgerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:requestLegacyExternalStorage="true"
        android:theme="@style/Theme.Ledger">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 透明 Activity：MediaProjection 授权（Android 10 截图替代方案） -->
        <activity
            android:name=".service.ScreenCaptureActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:exported="false" />

        <activity
            android:name=".ui.InputActivity"
            android:theme="@style/Theme.Ledger.Transparent.Floating"
            android:excludeFromRecents="true"
            android:taskAffinity="com.example.ledger.input" />

        <activity
            android:name=".ui.BillListActivity"
            android:label="@string/bill_list" />

        <activity
            android:name=".ui.StatisticsActivity"
            android:label="@string/statistics" />

        <activity
            android:name=".ui.SettingsActivity"
            android:label="@string/settings" />

        <activity
            android:name=".ui.CategoryManageActivity"
            android:label="@string/category_manage" />

        <service
            android:name=".ui.FloatingWindowService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <service
            android:name=".service.PaymentNotificationService"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- 测试广播接收器：ADB 触发退款识别测试 -->
        <receiver
            android:name=".service.TestReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.example.ledger.TEST_REFUND" />
            </intent-filter>
        </receiver>

        <!-- 屏幕识别无障碍服务：双击悬浮宠物后读取屏幕退款金额 -->
        <service
            android:name=".service.LedgerAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
